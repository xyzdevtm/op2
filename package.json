    "@opentelemetry/winston-transport": "^0.26.0",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "colord": "^2.9.3",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.18.1",
    "fastpriorityqueue": "^0.8.0",
    "howler": "^2.2.4",
